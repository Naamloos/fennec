<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Dev.Naamloos.Fennec.App.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:controls="clr-namespace:Dev.Naamloos.Fennec.App.Controls"
    xmlns:models="clr-namespace:Dev.Naamloos.Fennec.App.Models"
    xmlns:viewModels="clr-namespace:Dev.Naamloos.Fennec.App.ViewModels"
    x:Name="RootPage"
    x:DataType="viewModels:ChatViewModel"
    SafeAreaEdges="All"
    Title="{Binding Title}">
    <Grid RowDefinitions="*,Auto">
        <Grid>
            <controls:ChatVirtualList x:Name="MessagesCollectionView" ItemsSource="{Binding Messages}" IsVisible="{Binding IsRoomSelected}" Scrolled="OnMessagesScrolled">
                <controls:ChatVirtualList.ItemTemplate>
                    <DataTemplate x:DataType="models:ChatMessage">
                        <Grid>
                        <Grid
                            x:Name="EventRow"
                            IsVisible="{Binding IsNonMessageEvent}"
                            Padding="24,10"
                            HorizontalOptions="Fill">
                            <Grid.Behaviors>
                                <toolkit:TouchBehavior
                                    BindingContext="{Binding Source={x:Reference EventRow}, Path=BindingContext}"
                                    LongPressDuration="500"
                                    LongPressCommand="{Binding Source={x:Reference RootPage}, Path=BindingContext.OpenMessageActionsCommand}"
                                    LongPressCommandParameter="{Binding .}" />
                            </Grid.Behaviors>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center" MaximumWidthRequest="620">
                                <Label
                                    Text="{Binding Body}"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="WordWrap"
                                    Opacity="0.75" />
                                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="{Binding EventType}" FontSize="10" Opacity="0.5" VerticalTextAlignment="Center" />
                                    <Label Text="{Binding Time}" FontSize="10" Opacity="0.5" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                        <Grid
                            x:Name="MessageRow"
                            IsVisible="{Binding IsMessage}"
                            ColumnDefinitions="44,*,44"
                            ColumnSpacing="12"
                            Padding="{Binding RowPadding}">
                            <Grid.Behaviors>
                                <toolkit:TouchBehavior
                                    BindingContext="{Binding Source={x:Reference MessageRow}, Path=BindingContext}"
                                    LongPressDuration="500"
                                    LongPressCommand="{Binding Source={x:Reference RootPage}, Path=BindingContext.OpenMessageActionsCommand}"
                                    LongPressCommandParameter="{Binding .}" />
                            </Grid.Behaviors>
                            <Border
                                Grid.Column="{Binding AvatarColumn}"
                                IsVisible="{Binding ShowAuthor}"
                                WidthRequest="40"
                                HeightRequest="40"
                                StrokeThickness="0"
                                BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                                StrokeShape="RoundRectangle 20"
                                VerticalOptions="End">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.OpenProfileCommand}"
                                        CommandParameter="{Binding Source={x:Reference MessageRow}, Path=BindingContext}" />
                                </Border.GestureRecognizers>
                                <Grid>
                                    <Label Text="{Binding Initials}" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                    <Image Source="{Binding Avatar}" Aspect="AspectFill" />
                                </Grid>
                            </Border>
                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="5"
                                MaximumWidthRequest="520"
                                HorizontalOptions="{Binding MessageAlignment}">
                                <HorizontalStackLayout IsVisible="{Binding ShowAuthor}" Spacing="8" HorizontalOptions="{Binding MessageAlignment}">
                                    <Label Text="{Binding SenderName}" FontAttributes="Bold" HorizontalTextAlignment="{Binding TextAlignment}" />
                                    <Label Text="{Binding Time}" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Border
                                    Padding="10,8"
                                    StrokeThickness="0"
                                    BackgroundColor="{DynamicResource SurfaceContainer}"
                                    >
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="{Binding BubbleCorners}" />
                                    </Border.StrokeShape>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsOwn}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryContainer}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <VerticalStackLayout Spacing="7">
                                        <Border
                                            IsVisible="{Binding HasImage}"
                                            StrokeThickness="0"
                                            BackgroundColor="Transparent"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="0">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenImagePreviewCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Image
                                                Source="{Binding ContentImage}"
                                                Aspect="AspectFit"
                                                HeightRequest="260"
                                                MaximumWidthRequest="420" />
                                        </Border>
                                        <WebView
                                            IsVisible="{Binding HasPlayableMedia}"
                                            Source="{Binding MediaPlayerSource}"
                                            HeightRequest="{Binding MediaPlayerHeight}"
                                            MaximumWidthRequest="420"
                                            BackgroundColor="Transparent" />
                                        <Button
                                            IsVisible="{Binding HasFileAttachment}"
                                            Text="{Binding MediaFileName, StringFormat='Open {0}'}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenAttachmentCommand}"
                                            CommandParameter="{Binding .}"
                                            HorizontalOptions="Start" />
                                        <Label
                                            Text="{Binding Body}"
                                            IsVisible="{Binding HasPlainBody}"
                                            LineBreakMode="WordWrap"
                                            HorizontalTextAlignment="Start" />
                                        <Label
                                            FormattedText="{Binding FormattedBody}"
                                            IsVisible="{Binding HasFormattedBody}"
                                            LineBreakMode="WordWrap"
                                            HorizontalTextAlignment="Start" />
                                        <Label
                                            Text="{Binding SendState}"
                                            IsVisible="{Binding HasSendState}"
                                            FontSize="11"
                                            Opacity="0.7"
                                            HorizontalTextAlignment="Start" />
                                    </VerticalStackLayout>
                                </Border>
                                <FlexLayout
                                    IsVisible="{Binding HasReactions}"
                                    BindableLayout.ItemsSource="{Binding Reactions}"
                                    Direction="Row"
                                    Wrap="Wrap"
                                    JustifyContent="Start">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:ChatReaction">
                                            <Button
                                                Text="{Binding Label}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleReactionCommand}"
                                                CommandParameter="{Binding .}"
                                                Padding="8,2"
                                                Margin="0,3,4,0"
                                                FontSize="12"
                                                MinimumHeightRequest="28" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </FlexLayout>
                                <Label
                                    Text="{Binding ReadReceiptText}"
                                    IsVisible="{Binding HasReadReceipts}"
                                    FontSize="10"
                                    TextColor="{DynamicResource Primary}"
                                    HorizontalTextAlignment="End" />
                            </VerticalStackLayout>
                        </Grid>
                        <Border
                            IsVisible="{Binding IsActionsOpen}"
                            ZIndex="20"
                            Margin="28,4"
                            Padding="8"
                            HorizontalOptions="{Binding MessageAlignment}"
                            VerticalOptions="Start"
                            BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                            Stroke="{DynamicResource Outline}"
                            StrokeShape="RoundRectangle 18">
                            <VerticalStackLayout Spacing="6">
                                <ScrollView IsVisible="{Binding IsMessage}" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Source={x:Reference RootPage}, Path=BindingContext.ReactionChoices}" Spacing="2">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="{x:Null}">
                                                <Button Text="{Binding .}" Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.ReactCommand}" CommandParameter="{Binding .}" FontSize="18" Padding="6,1" MinimumHeightRequest="30" />
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </HorizontalStackLayout>
                                </ScrollView>
                                <HorizontalStackLayout Spacing="4">
                                    <Button Text="Reply" IsVisible="{Binding IsMessage}" Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.ReplyToSelectedCommand}" Padding="8,2" />
                                    <Button Text="Profile" IsVisible="{Binding IsMessage}" Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.OpenProfileCommand}" CommandParameter="{Binding .}" Padding="8,2" />
                                    <Button Text="Source" Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.ViewSelectedSourceCommand}" Padding="8,2" />
                                    <Button Text="Delete" IsVisible="{Binding Source={x:Reference RootPage}, Path=BindingContext.CanRedactSelectedMessage}" Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.RequestRedactCommand}" Padding="8,2" />
                                    <Button Text="×" Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.CloseMessageActionsCommand}" Padding="8,2" BackgroundColor="Transparent" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                        </Grid>
                    </DataTemplate>
                </controls:ChatVirtualList.ItemTemplate>
            </controls:ChatVirtualList>
            <ActivityIndicator
                IsVisible="{Binding IsLoadingOlder}"
                IsRunning="{Binding IsLoadingOlder}"
                HorizontalOptions="Center"
                VerticalOptions="Start"
                Margin="0,8"
                ZIndex="2" />
            <Grid
                IsVisible="{Binding IsSpaceOverview}"
                RowDefinitions="Auto,*"
                Padding="24,20"
                RowSpacing="20">
                <Border
                    Padding="20"
                    StrokeThickness="0"
                    BackgroundColor="{DynamicResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 24">
                    <Grid ColumnDefinitions="72,*" ColumnSpacing="18">
                        <Border
                            WidthRequest="72"
                            HeightRequest="72"
                            StrokeThickness="0"
                            BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                            StrokeShape="RoundRectangle 18">
                            <Grid>
                                <Label
                                    Text="{Binding Space.Initials}"
                                    FontSize="24"
                                    FontAttributes="Bold"
                                    HorizontalTextAlignment="Center"
                                    VerticalTextAlignment="Center" />
                                <Image Source="{Binding Space.Avatar}" Aspect="AspectFill" />
                            </Grid>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                            <Label Text="Space" FontSize="12" FontAttributes="Bold" Opacity="0.65" TextTransform="Uppercase" />
                            <Label Text="{Binding Space.Name}" FontSize="26" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Space.Description}" Opacity="0.72" LineBreakMode="WordWrap" />
                            <Label Text="{Binding Space.AllRooms.Count, StringFormat='{0} channels'}" Opacity="0.7" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
                <CollectionView Grid.Row="1" ItemsSource="{Binding Space.AllRooms}" EmptyView="This space has no joined channels.">
                    <CollectionView.Header>
                        <Label Text="Channels" FontSize="18" FontAttributes="Bold" Margin="4,0,4,10" />
                    </CollectionView.Header>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:RoomListItem">
                            <Border
                                Margin="0,4"
                                Padding="14,10"
                                StrokeThickness="0"
                                BackgroundColor="{DynamicResource Surface}"
                                StrokeShape="RoundRectangle 16"
                                SemanticProperties.Description="{Binding Name, StringFormat='Open channel {0}'}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenOverviewRoomCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">
                                    <Border
                                        WidthRequest="36"
                                        HeightRequest="36"
                                        StrokeThickness="0"
                                        BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                                        StrokeShape="RoundRectangle 18">
                                        <Grid>
                                            <Label Text="{Binding Initials}" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Image Source="{Binding Avatar}" Aspect="AspectFill" />
                                        </Grid>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding Topic}" FontSize="11" Opacity="0.65" MaxLines="2" LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding MemberCount, StringFormat='{0} members'}" FontSize="10" Opacity="0.55" />
                                    </VerticalStackLayout>
                                    <Button
                                        Grid.Column="2"
                                        Text="Join"
                                        IsVisible="{Binding IsJoinable}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenOverviewRoomCommand}"
                                        CommandParameter="{Binding .}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
            <Label Text="Open the sidebar and choose a room" IsVisible="{Binding IsEmpty}" TextColor="{DynamicResource OnSurfaceVariant}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
            <Button
                IsVisible="{Binding IsRoomSelected}"
                Text="Members"
                Command="{Binding ToggleMemberListCommand}"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="12"
                ZIndex="5" />
        </Grid>
        <VerticalStackLayout Grid.Row="1" IsVisible="{Binding IsRoomSelected}" Padding="16,4,16,12" Spacing="6">
            <Label Text="{Binding TypingText}" FontSize="11" TextColor="{DynamicResource OnSurfaceVariant}" Margin="52,0,0,0" />
            <Border IsVisible="{Binding IsReplying}" Padding="12,8" Margin="52,0,0,0" BackgroundColor="{DynamicResource SurfaceContainer}" StrokeThickness="0" StrokeShape="RoundRectangle 14">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <VerticalStackLayout Spacing="1">
                        <Label Text="{Binding ReplyingTo.SenderName, StringFormat='Replying to {0}'}" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                        <Label Text="{Binding ReplyingTo.Body}" FontSize="11" MaxLines="1" LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="Cancel" Command="{Binding CancelReplyCommand}" BackgroundColor="Transparent" />
                </Grid>
            </Border>
            <Border IsVisible="{Binding IsMentionPickerOpen}" Margin="52,0,0,0" Padding="8" BackgroundColor="{DynamicResource SurfaceContainerHigh}" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding MentionSuggestions}" Spacing="2">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:RoomMemberItem">
                            <Button Text="{Binding DisplayName}" HorizontalOptions="Fill" BackgroundColor="Transparent" Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.SelectMentionCommand}" CommandParameter="{Binding .}" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </Border>
            <Border
                IsVisible="{Binding IsAttachmentMenuOpen}"
                Padding="10"
                BackgroundColor="{DynamicResource SurfaceContainer}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20">
                <FlexLayout Direction="Row" Wrap="Wrap" JustifyContent="Start">
                    <Button Text="Image" Command="{Binding PickImageCommand}" />
                    <Button Text="File" Command="{Binding PickFileCommand}" />
                    <Button Text="Video" Command="{Binding PickVideoCommand}" />
                    <Button Text="{Binding VoiceActionLabel}" Command="{Binding RecordVoiceCommand}" />
                    <Button Text="Sticker" Command="{Binding ToggleStickerPickerCommand}" />
                    <ActivityIndicator IsRunning="{Binding IsUploadingImage}" IsVisible="{Binding IsUploadingImage}" />
                </FlexLayout>
            </Border>
            <FlexLayout
                IsVisible="{Binding IsEmojiPickerOpen}"
                BindableLayout.ItemsSource="{Binding ReactionChoices}"
                Direction="Row"
                JustifyContent="Center">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="{x:Null}">
                        <Button
                            Text="{Binding .}"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.InsertEmojiCommand}"
                            CommandParameter="{Binding .}"
                            Padding="8,2"
                            Margin="2"
                            FontSize="18" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
            <FlexLayout
                IsVisible="{Binding IsEmojiPickerOpen}"
                BindableLayout.ItemsSource="{Binding CustomEmojis}"
                Direction="Row"
                Wrap="Wrap"
                JustifyContent="Center">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:MatrixImageAsset">
                        <Border WidthRequest="42" HeightRequest="42" Margin="2" Padding="4" BackgroundColor="{DynamicResource SurfaceContainer}" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.InsertCustomEmojiCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Image Source="{Binding Image}" Aspect="AspectFit" />
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
            <ScrollView IsVisible="{Binding IsStickerPickerOpen}" Orientation="Horizontal" MaximumHeightRequest="130">
                <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Stickers}" Spacing="8" Padding="4">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:MatrixImageAsset">
                            <Border WidthRequest="104" HeightRequest="104" Padding="8" BackgroundColor="{DynamicResource SurfaceContainer}" StrokeThickness="0" StrokeShape="RoundRectangle 18">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SendStickerCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Image Source="{Binding Image}" Aspect="AspectFit" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="52,0,0,0">
                <HorizontalStackLayout Spacing="2">
                    <Button Text="B" FontAttributes="Bold" Command="{Binding FormatSelectionCommand}" CommandParameter="bold" Padding="8,0" BackgroundColor="Transparent" />
                    <Button Text="I" FontAttributes="Italic" Command="{Binding FormatSelectionCommand}" CommandParameter="italic" Padding="8,0" BackgroundColor="Transparent" />
                    <Button Text="S̶" Command="{Binding FormatSelectionCommand}" CommandParameter="strike" Padding="8,0" BackgroundColor="Transparent" />
                    <Button Text="&lt;/&gt;" Command="{Binding FormatSelectionCommand}" CommandParameter="code" Padding="8,0" BackgroundColor="Transparent" />
                    <Button Text="Link" Command="{Binding FormatSelectionCommand}" CommandParameter="link" Padding="8,0" BackgroundColor="Transparent" />
                    <Button Text="Quote" Command="{Binding FormatSelectionCommand}" CommandParameter="quote" Padding="8,0" BackgroundColor="Transparent" />
                    <Button Text="List" Command="{Binding FormatSelectionCommand}" CommandParameter="list" Padding="8,0" BackgroundColor="Transparent" />
                </HorizontalStackLayout>
            </ScrollView>
            <Border IsVisible="{Binding HasComposerPreview}" Margin="52,0,0,0" Padding="10,6" BackgroundColor="{DynamicResource SurfaceContainer}" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Preview" FontSize="10" TextColor="{DynamicResource OnSurfaceVariant}" />
                    <Label FormattedText="{Binding ComposerPreview}" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>
            <Border
                Padding="8"
                BackgroundColor="{DynamicResource SurfaceContainer}"
                Stroke="{DynamicResource Outline}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 26">
                <Grid ColumnDefinitions="44,Auto,*,48" ColumnSpacing="6">
                    <Border WidthRequest="42" HeightRequest="42" StrokeThickness="0" BackgroundColor="{DynamicResource PrimaryContainer}" StrokeShape="RoundRectangle 21">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleAttachmentsCommand}" />
                        </Border.GestureRecognizers>
                        <Path Data="M 12,4 L 12,20 M 4,12 L 20,12" Stroke="{DynamicResource OnPrimaryContainer}" StrokeThickness="2.4" StrokeLineCap="Round" WidthRequest="24" HeightRequest="24" />
                    </Border>
                    <Button Grid.Column="1" Text="☺" Command="{Binding ToggleEmojiPickerCommand}" Padding="8,0" FontSize="20" BackgroundColor="Transparent" />
                    <Editor
                        Grid.Column="2"
                        Text="{Binding SendText}"
                        CursorPosition="{Binding ComposerCursorPosition, Mode=TwoWay}"
                        SelectionLength="{Binding ComposerSelectionLength, Mode=TwoWay}"
                        Placeholder="Message this room"
                        AutoSize="TextChanges"
                        MaximumHeightRequest="140"
                        BackgroundColor="Transparent" />
                    <Border Grid.Column="3" WidthRequest="44" HeightRequest="44" StrokeThickness="0" BackgroundColor="{DynamicResource Primary}" StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SendCommand}" />
                        </Border.GestureRecognizers>
                        <Path Data="M 4,12 L 20,4 L 14,20 L 11,13 Z" Fill="{DynamicResource OnPrimary}" WidthRequest="24" HeightRequest="24" />
                    </Border>
                </Grid>
            </Border>
        </VerticalStackLayout>
        <Grid
            Grid.RowSpan="2"
            IsVisible="{Binding IsMemberListOpen}"
            BackgroundColor="{DynamicResource Scrim}"
            ZIndex="70">
            <Border
                WidthRequest="340"
                Padding="18"
                HorizontalOptions="End"
                VerticalOptions="Fill"
                BackgroundColor="{DynamicResource Surface}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24,0,0,24">
                <Grid RowDefinitions="Auto,*" RowSpacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Members" FontSize="24" FontAttributes="Bold" VerticalTextAlignment="Center" />
                        <Button Grid.Column="1" Text="Close" Command="{Binding ToggleMemberListCommand}" />
                    </Grid>
                    <CollectionView Grid.Row="1" ItemsSource="{Binding Members}" EmptyView="Loading members…">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:RoomMemberItem">
                                <Grid ColumnDefinitions="40,*" ColumnSpacing="10" Padding="4,7">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenMemberProfileCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Border WidthRequest="38" HeightRequest="38" BackgroundColor="{DynamicResource SurfaceContainerHigh}" StrokeThickness="0" StrokeShape="RoundRectangle 19">
                                        <Grid>
                                            <Label Text="{Binding Initials}" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                            <Image Source="{Binding Avatar}" Aspect="AspectFill" />
                                        </Grid>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                        <Label Text="{Binding DisplayName}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding Role}" FontSize="10" Opacity="0.6" />
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </Grid>
        <Border
            Grid.RowSpan="2"
            IsVisible="{Binding IsProfileOpen}"
            WidthRequest="340"
            Margin="24"
            Padding="18"
            HorizontalOptions="End"
            VerticalOptions="Start"
            BackgroundColor="{DynamicResource Surface}"
            Stroke="{DynamicResource Outline}"
            StrokeShape="RoundRectangle 24"
            ZIndex="90">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Fill">
                    <Border WidthRequest="96" HeightRequest="96" HorizontalOptions="Center" BackgroundColor="{DynamicResource SurfaceContainerHigh}" StrokeThickness="0" StrokeShape="RoundRectangle 48">
                        <Image Source="{Binding ProfileAvatar}" Aspect="AspectFill" />
                    </Border>
                    <Label Text="{Binding ProfileDisplayName}" FontSize="24" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding ProfileUserId}" FontSize="12" Opacity="0.65" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding ProfileRole}" FontSize="12" Opacity="0.65" HorizontalTextAlignment="Center" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="Mention" Command="{Binding MentionProfileCommand}" />
                        <Button Grid.Column="1" Text="Close" Command="{Binding CloseProfileCommand}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Text="Kick" Command="{Binding RequestKickCommand}" IsVisible="{Binding CanKickProfile}" />
                        <Button Grid.Column="1" Text="Ban" Command="{Binding RequestBanCommand}" IsVisible="{Binding CanBanProfile}" />
                    </Grid>
                </VerticalStackLayout>
        </Border>
        <Grid
            Grid.RowSpan="2"
            IsVisible="{Binding IsSourceInspectorOpen}"
            BackgroundColor="{DynamicResource AppBackground}"
            Padding="24,20"
            RowDefinitions="Auto,*"
            RowSpacing="16"
            ZIndex="110">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="3" VerticalOptions="Center">
                    <Label Text="Event source" FontSize="22" FontAttributes="Bold" />
                    <Label Text="{Binding InspectedEventType}" FontSize="12" Opacity="0.65" />
                </VerticalStackLayout>
                <HorizontalStackLayout Grid.Column="1" Spacing="8">
                    <Button
                        Text="Copy"
                        Command="{Binding CopySourceCommand}"
                        SemanticProperties.Description="Copy raw Matrix event source" />
                    <Border
                        WidthRequest="48"
                        HeightRequest="48"
                        Padding="12"
                        BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24"
                        SemanticProperties.Description="Close event source">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CloseSourceInspectorCommand}" />
                        </Border.GestureRecognizers>
                        <Path
                            Data="M 4,4 L 20,20 M 20,4 L 4,20"
                            Stroke="{DynamicResource OnSurface}"
                            StrokeThickness="2.5"
                            StrokeLineCap="Round"
                            WidthRequest="24"
                            HeightRequest="24" />
                    </Border>
                </HorizontalStackLayout>
            </Grid>
            <Border
                Grid.Row="1"
                Padding="2"
                BackgroundColor="{DynamicResource SurfaceContainer}"
                Stroke="{DynamicResource Outline}"
                StrokeShape="RoundRectangle 16">
                <Editor
                    Text="{Binding InspectedSource}"
                    IsReadOnly="True"
                    AutoSize="Disabled"
                    FontFamily="Consolas"
                    FontSize="12"
                    Margin="12"
                    BackgroundColor="Transparent"
                    SemanticProperties.Description="Raw Matrix event JSON" />
            </Border>
        </Grid>
        <Grid
            Grid.RowSpan="2"
            IsVisible="{Binding IsImagePreviewOpen}"
            BackgroundColor="#F0000000"
            ZIndex="100">
            <Image
                Source="{Binding PreviewImage}"
                Aspect="AspectFit"
                Margin="24,72,24,24" />
            <ActivityIndicator
                IsVisible="{Binding IsLoadingPreview}"
                IsRunning="{Binding IsLoadingPreview}"
                Color="White"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
            <Border
                WidthRequest="48"
                HeightRequest="48"
                Margin="16"
                Padding="12"
                HorizontalOptions="End"
                VerticalOptions="Start"
                BackgroundColor="#66000000"
                Stroke="White"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                SemanticProperties.Description="Close image preview">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseImagePreviewCommand}" />
                </Border.GestureRecognizers>
                <Path
                    Data="M 4,4 L 20,20 M 20,4 L 4,20"
                    Stroke="White"
                    StrokeThickness="2.5"
                    StrokeLineCap="Round"
                    WidthRequest="24"
                    HeightRequest="24" />
            </Border>
        </Grid>
    </Grid>
</ContentPage>
