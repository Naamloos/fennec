<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Dev.Naamloos.Fennec.App.Controls.RoomGroupHeader"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:Dev.Naamloos.Fennec.App.Models"
    x:DataType="models:RoomGroup">
    <Grid ColumnDefinitions="*,44" Padding="0,6,0,0">
        <Grid
            ColumnDefinitions="28,*"
            ColumnSpacing="10"
            Padding="8,10"
            SemanticProperties.Description="{Binding Name, StringFormat='Open or expand {0}'}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding OpenCommand}" />
            </Grid.GestureRecognizers>
            <Border
                WidthRequest="24"
                HeightRequest="24"
                StrokeThickness="0"
                BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                StrokeShape="RoundRectangle 6">
                <Grid>
                    <Label
                        Text="{Binding Initials}"
                        FontSize="11"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"
                        VerticalTextAlignment="Center" />
                    <Image Source="{Binding Avatar}" Aspect="AspectFill" />
                </Grid>
            </Border>
            <Label
                Grid.Column="1"
                Text="{Binding Name}"
                FontAttributes="Bold"
                VerticalTextAlignment="Center"
                LineBreakMode="TailTruncation" />
        </Grid>
        <Border
            Grid.Column="1"
            WidthRequest="40"
            HeightRequest="40"
            StrokeThickness="0"
            BackgroundColor="Transparent"
            StrokeShape="RoundRectangle 20"
            SemanticProperties.Description="Expand or collapse channels">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleCommand}" />
            </Border.GestureRecognizers>
            <Path
                Data="M 4,7 L 10,13 L 16,7"
                Stroke="{DynamicResource OnSurfaceVariant}"
                StrokeThickness="2"
                StrokeLineCap="Round"
                StrokeLineJoin="Round"
                Rotation="{Binding ChevronRotation}"
                WidthRequest="20"
                HeightRequest="20"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        </Border>
    </Grid>
</ContentView>
