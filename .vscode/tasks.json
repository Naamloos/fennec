{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build Fennec (Windows)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Dev.Naamloos.Fennec.App/Dev.Naamloos.Fennec.App.csproj",
        "-f",
        "net10.0-windows10.0.19041.0"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build Fennec (Android)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/Dev.Naamloos.Fennec.App/Dev.Naamloos.Fennec.App.csproj",
        "-f",
        "net10.0-android",
        "-t:InstallAndroidDependencies"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "type": "maui",
      "targetFramework": "net10.0-android",
      "configuration": "Debug",
      "project": "C:\\Source\\fennec\\Dev.Naamloos.Fennec.App\\Dev.Naamloos.Fennec.App.csproj",
      "problemMatcher": [
        "$msCompile",
        "maui-problem-matcher-location",
        "maui-problem-matcher",
        "maui-problem-matcher-location-multiline",
        "maui-problem-matcher-multiline"
      ],
      "label": "maui: Build"
    },
    {
      "type": "maui",
      "targetFramework": "net10.0-windows10.0.19041.0",
      "configuration": "Debug",
      "project": "C:\\Source\\fennec\\Dev.Naamloos.Fennec.App\\Dev.Naamloos.Fennec.App.csproj",
      "problemMatcher": [
        "$msCompile",
        "maui-problem-matcher-location",
        "maui-problem-matcher",
        "maui-problem-matcher-location-multiline",
        "maui-problem-matcher-multiline"
      ],
      "label": "maui: Build"
    }
  ]
}
